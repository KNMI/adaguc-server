<?xml version="1.0" encoding="UTF-8"?>
<Configuration>

  <Legend name="warning_vector_legend" type="interval">
    <palette min="0"  max="5"  red="255" green="255" blue="0"   alpha="255"/>
    <palette min="5"  max="15" red="255" green="123" blue="0"   alpha="255"/>
    <palette min="15" max="50" red="255" green="0"   blue="0"   alpha="255"/>
  </Legend>

  
  <Style name="warning_vectors_per_feature" title="Warning vectors per feature">
    <Legend fixed="true">warning_vector_legend</Legend>
    <ShadeInterval min="0"  max="5"  label="0-5 m/s"  fillcolor="#FFFF00FF"/>
    <ShadeInterval min="5"  max="15" label="5-15 m/s" fillcolor="#FF7B00FF"/>
    <ShadeInterval min="15" max="50" label="15+ m/s"  fillcolor="#FF0000FF"/>
    <Vector min="0" max="5" vectorstyle="vector" linewidth="2" linecolor="#FFFF00" scale="10" plotvalue="true" textcolor="#000000"/>
    <Vector min="5" max="15" vectorstyle="vector" linewidth="3" linecolor="#FF7B00" scale="10" plotvalue="true" textcolor="#000000" />
    <Vector min="15" vectorstyle="vector" linewidth="5" linecolor="#FF0000" scale="10" />
    <RenderMethod>point</RenderMethod>
    <DataPostProc algorithm="pointsfromfeature" select="speed_ms,direction_degrees"/>
  </Style>

  <Style name="polygon_per_feature_code" title="Polygons per feature code">
    <RenderMethod>polygon</RenderMethod>
    <FeatureInterval match="1" matchid="warning_code" linecolor="#000000" linewidth="1" fillcolor="#FF0000FF" />
    <FeatureInterval match="2" matchid="warning_code" linecolor="#000000" linewidth="1" fillcolor="#FFFF00FF"/>
    <FeatureInterval match="3" matchid="warning_code" linecolor="#000000" linewidth="1" fillcolor="#00FF00FF"/>
  </Style>
  
  <Style name="polygon_innerparts_coloured" title="Polygons per code leadtime">
    <RenderMethod>polygon</RenderMethod>
    <FeatureInterval match="1" matchid="warning_code_leadtime" fillcolor="#CCCCCCFF" linecolor="#000000" linewidth="1"/>
    <FeatureInterval match="2_15" matchid="warning_code_leadtime" fillcolor="#FFFF0080" linecolor="#000000" linewidth="1"/>
    <FeatureInterval match="2_30" matchid="warning_code_leadtime" fillcolor="#FFFF8080" linecolor="#000000" linewidth="1"/>
    <FeatureInterval match="2_60" matchid="warning_code_leadtime" fillcolor="#CCCCCC80" linecolor="#000000" linewidth="1"/>
    <FeatureInterval match="3_15" matchid="warning_code_leadtime" fillcolor="#FF800080" linecolor="#000000" linewidth="1"/>
    <FeatureInterval match="3_30" matchid="warning_code_leadtime" fillcolor="#FFa08080" linecolor="#000000" linewidth="1"/>
    <FeatureInterval match="3_60" matchid="warning_code_leadtime" fillcolor="#CCCCCC80" linecolor="#000000" linewidth="1"/>
    <FeatureInterval match="4_15" matchid="warning_code_leadtime" fillcolor="#FF000080" linecolor="#000000" linewidth="1"/>
    <FeatureInterval match="4_30" matchid="warning_code_leadtime" fillcolor="#FF808080" linecolor="#000000" linewidth="1"/>
    <FeatureInterval match="4_60" matchid="warning_code_leadtime" fillcolor="#CCCCCC80" linecolor="#000000" linewidth="1"/>
  </Style>
  
  
  <Layer type="database">
    <Name>pff_test</Name>
    <Title>GeoJSON Points From Feature Test</Title>
    <FilePath>{ADAGUC_PATH}data/datasets/geojsons/warnings.example.geojson</FilePath>
    
    <Variable>features</Variable>
    
    <Styles>warning_vectors_per_feature,polygon_per_feature_code,polygon_innerparts_coloured</Styles> 
  </Layer>


  <Layer type="database">
    <Name>pff_test_points_and_features</Name>
    <Title>GeoJSON Points From Feature Test</Title>
    <FilePath>{ADAGUC_PATH}data/datasets/geojsons/warnings.example.geojson</FilePath>
    <Variable>features</Variable>
    <Styles>polygon_per_feature_code</Styles>
    <AdditionalLayer replace="false" style="warning_vectors_per_feature">pff_test</AdditionalLayer>
  </Layer>
  
</Configuration>